# Postgres
POSTGRES_USER=recipe
POSTGRES_PASSWORD=change-me-to-something-secure
POSTGRES_DB=recipedb

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI registered in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:80/api/auth/google/callback
# Where to send the user after login (frontend origin)
FRONTEND_URL=http://localhost:80

# Parser backend: "local" (free, uses Tesseract) or "ai" (requires OpenAI key)
PARSER_BACKEND=local
OPENAI_API_KEY=

# Port to expose the web UI on
PORT=80
